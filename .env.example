# Shared secret for the thermal-printer API on berendswennenhuis.nl.
# Must match THERMAL_PRINTER_TOKEN in the berendswennenhuis.nl stack.
#
# NOTE: the NUXT_ prefix is required. Nuxt only overrides runtimeConfig.printerPassword
# from an env var named NUXT_PRINTER_PASSWORD at runtime; a plain PRINTER_PASSWORD is
# only used as a build-time default and is ignored in the built (production) server.
NUXT_PRINTER_PASSWORD=
